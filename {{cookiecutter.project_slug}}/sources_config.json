{
  "_comment": "{{ cookiecutter.project_name }} — Sources Configuration. Liga/desliga fontes sem mudar código.",
  "_topic": "{{ cookiecutter.newsletter_topic }}",
  "_curation_style": "{{ cookiecutter.curation_style }}",

  "sources": {
    "reddit": {
      "enabled": true,
      "weight": 1.0,
      "subreddits": {{ cookiecutter.reddit_subreddits.split(',') | map('trim') | list | tojson }},
      "limit_per_sub": 10,
      "rate_limit_delay": 0.5
    },
    "hackernews": {
      "enabled": true,
      "weight": 1.2,
      "limit": 30,
      "timeout": 15
    },
    "rss_extra_1": {
      "enabled": false,
      "_comment": "Adicione um feed RSS relevante pro seu tema. Ative mudando 'enabled' pra true.",
      "weight": 1.0,
      "limit": 20,
      "rss_url": "https://example.com/feed"
    },
    "rss_extra_2": {
      "enabled": false,
      "_comment": "Segundo feed RSS opcional.",
      "weight": 1.0,
      "limit": 20,
      "rss_url": "https://example.com/feed"
    }
  },

  "pre_filter": {
    "recency_hours": {{ 24 if cookiecutter.schedule_frequency == 'daily' else 168 }},
    "recency_fallback_min_items": 10,
    "max_items_to_llm": 40,
    "dedup_similarity_threshold": 0.7,
    "max_per_source_pct": 0.25,
    "wild_card_slots": 5
  },

  "scoring": {
    "recency_decay_constant": {{ 8 if cookiecutter.schedule_frequency == 'daily' else 24 }},
    "engagement_weight": 0.4,
    "recency_weight": 0.3,
    "source_diversity_weight": 0.2,
    "category_weight": 0.1
  }
}
